; fizzbuzz.anc — FizzBuzz 1..30
; Shows: functions, while loops, conditionals, modulo, FFI

(include <stdio.h>)

(fn divisible? (n d)
  (return (== (% n d) 0)))

(fn fizzbuzz (n)
  (let fizz (divisible? n 3))
  (let buzz (divisible? n 5))
  (if (&& fizz buzz)
    (print "FizzBuzz\n")
    (if fizz
      (print "Fizz\n")
      (if buzz
        (print "Buzz\n")
        (print "%d\n" n)))))

(with-arena
  (fn main ()
    (let i 1)
    (while (<= i 30)
      (fizzbuzz i)
      (set! i (+ i 1)))))
